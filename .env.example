# Backend configuration for Gemini AI
# Use either a Google API key (AIza...) or an OAuth bearer token (ya29...)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: override the Gemini endpoint if needed
# Default endpoint uses the supported Generative Language API:
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-pro:generateContent
# You can also choose a Flash variant:
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# Frontend: custom AI endpoint (optional)
# VITE_AI_API_URL=http://localhost:5000/api/chat
